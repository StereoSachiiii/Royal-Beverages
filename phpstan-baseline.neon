parameters:
	ignoreErrors:
		-
			message: '#^Strict comparison using \=\=\= between true and true will always evaluate to true\.$#'
			identifier: identical.alwaysTrue
			count: 1
			path: src/Admin/API/Routes/FeedbackRoutes.php

		-
			message: '#^PHPDoc tag @param has invalid value \(\?Throwable\|null \$previous\)\: Unexpected token "\|", expected variable at offset 255 on line 6$#'
			identifier: phpDoc.parseError
			count: 1
			path: src/Admin/Exceptions/DuplicateEmailException.php

		-
			message: '#^Ternary operator condition is always true\.$#'
			identifier: ternary.alwaysTrue
			count: 1
			path: src/Admin/Repositories/ProductRepository.php

		-
			message: '#^Parameter \#3 \$value of function curl_setopt expects bool, int given\.$#'
			identifier: argument.type
			count: 1
			path: src/Admin/Services/AIRecommendationService.php

		-
			message: '#^Strict comparison using \=\=\= between mixed and null will always evaluate to false\.$#'
			identifier: identical.alwaysFalse
			count: 1
			path: src/Admin/Services/OrderItemService.php

		-
			message: '#^Parameter \#2 \$context of class App\\Admin\\Exceptions\\ValidationException constructor expects array\{field\?\: string\|null, value\?\: string\|null\}, non\-empty\-array\<non\-falsy\-string, array\> given\.$#'
			identifier: argument.type
			count: 1
			path: src/Admin/Services/RecipeIngredientService.php

		-
			message: '#^Negated boolean expression is always false\.$#'
			identifier: booleanNot.alwaysFalse
			count: 1
			path: src/Admin/Services/UserService.php

		-
			message: '#^Expression on left side of \?\? is not nullable\.$#'
			identifier: nullCoalesce.expr
			count: 1
			path: src/Core/Autoloader.php

		-
			message: '#^Parameter \#1 \$callback of function spl_autoload_register expects \(callable\(string\)\: void\)\|null, array\{\$this\(App\\Core\\Autoloader\), ''loadClass''\} given\.$#'
			identifier: argument.type
			count: 1
			path: src/Core/Autoloader.php

		-
			message: '#^Call to function method_exists\(\) with App\\Core\\Request and ''getAllBody'' will always evaluate to true\.$#'
			identifier: function.alreadyNarrowedType
			count: 1
			path: src/Core/Router.php

		-
			message: '#^Call to function method_exists\(\) with App\\Core\\Request and ''getBody'' will always evaluate to true\.$#'
			identifier: function.alreadyNarrowedType
			count: 1
			path: src/Core/Router.php

		-
			message: '#^Offset ''middleware'' on array\{pattern\: string, paramNames\: array, handler\: array\|\(callable\(\)\: mixed\)\} on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: src/Core/Router.php

		-
			message: '#^Variable \$routeMiddleware in empty\(\) always exists and is always falsy\.$#'
			identifier: empty.variable
			count: 1
			path: src/Core/Router.php

		-
			message: '#^Property App\\Core\\Session\:\:\$csrf in isset\(\) is not nullable nor uninitialized\.$#'
			identifier: isset.initializedProperty
			count: 1
			path: src/Core/Session.php

		-
			message: '#^Parameter \#1 \$callback of function spl_autoload_register expects \(callable\(string\)\: void\)\|null, array\{\$this\(App\\DIContainer\\Autoloader\), ''loadClass''\} given\.$#'
			identifier: argument.type
			count: 1
			path: src/DIContainer/Autoloader.php

		-
			message: '#^Property App\\Validation\\Rules\\MaxRule\:\:\$max \(float\|int\) is never assigned int so it can be removed from the property type\.$#'
			identifier: property.unusedType
			count: 1
			path: src/Validation/Rules/MaxRule.php

		-
			message: '#^Property App\\Validation\\Rules\\MinRule\:\:\$min \(float\|int\) is never assigned int so it can be removed from the property type\.$#'
			identifier: property.unusedType
			count: 1
			path: src/Validation/Rules/MinRule.php
