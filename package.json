{
  "name": "royal-liquor",
  "version": "1.0.0",
  "description": "An **OKAY-grade e-commerce application** built strictly with **Vanilla PHP** and **Pure JavaScript** — demonstrating mastery of web fundamentals through custom-built architecture.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "php vendor/phpunit/phpunit/phpunit",
    "build:css": "npx tailwindcss -i ./public/css/royal.css -o ./public/css/main.css --minify",
    "dev:css": "npx tailwindcss -i ./public/css/royal.css -o ./public/css/main.css --watch",
    "lint": "eslint \"public/**/*.js\" --no-error-on-unmatched-pattern",
    "format": "prettier --write \"public/**/*.js\" \"public/css/**/*.css\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StereoSachiiii/Royal-Beverages.git"
  },
  "bugs": {
    "url": "https://github.com/StereoSachiiii/Royal-Beverages/issues"
  },
  "homepage": "https://github.com/StereoSachiiii/Royal-Beverages#readme"
}
